# direnv configuration for chatgpt-bulk-downloader
# This file is committed. It sources the local (untracked) overrides.

# Load from parent folder first (for shared HF, GH, CONTEXT7, CODACY_ACCOUNT etc.)
source_up

# Load local secrets and project-specific env (never commit .envrc.local)
source_env_if_exists .envrc.local

# Optional: ensure project root is known
export CHATGPT_BULK_DOWNLOADER_ROOT=$(pwd)

# If using Speckit or gh heavily, ensure tokens from .envrc.local are present.
# Run commands with: direnv exec . <command> if outside the direnv shell.

# Example for gh token export if needed for MCP/tools:
# if [ -n "${GH_TOKEN:-}" ]; then
#   export GITHUB_TOKEN="$GH_TOKEN"
# fi
